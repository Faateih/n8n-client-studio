# ─────────────────────────────────────────────────────────────────────────────
# n8n-client-studio — LOCAL RUNTIME CONFIGURATION ONLY
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running Docker Compose.
#
#   cp .env.example .env
#
# IMPORTANT — what belongs here vs. in n8n:
#
#   ✅  This file    → settings that configure the local n8n container/instance
#   ❌  This file    → client API keys, webhook secrets, OAuth tokens, or any
#                      credential your workflows need to call external services
#
#   All workflow credentials must be created in the n8n Credentials UI
#   (Settings → Credentials → New).  Never paste them here.
#   See docs/setup.md for the full explanation.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Public webhook base URL — must match what external services will call.
# For local dev, ngrok or similar tunnels work well.
# Example with ngrok: WEBHOOK_URL=https://abc123.ngrok.io
WEBHOOK_URL=http://localhost:5678

# ── Basic Auth ───────────────────────────────────────────────────────────────
# Protects the n8n UI when running locally.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme     # ← change this

# ── Timezone ─────────────────────────────────────────────────────────────────
# Used for cron triggers and execution timestamps.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE=America/New_York
